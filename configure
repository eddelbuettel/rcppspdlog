#!/bin/sh

set -eu

os=$(uname)
mach=$(uname -m)

echo "** configuring for ${os} on ${mach}"
if [ "${os}" = "Darwin" ] && [ "${mach}" = "x86_64" ]; then
   echo "** selecting C++17 as compilation standard"
   sed -e 's|@CXX_STD@|CXX_STD=CXX17|' src/Makevars.in > src/Makevars
else
   # Defaults are fine elsewhere
   sed -e 's|@CXX_STD@||' src/Makevars.in > src/Makevars
fi
